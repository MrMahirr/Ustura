# ============================================================
# USTURA — Ortam Değişkenleri (Örnek)
# Bu dosyayı .env olarak kopyalayıp değerleri doldurun
# ============================================================

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ustura
DB_USER=postgres
DB_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Backend
PORT=3000
NODE_ENV=development
