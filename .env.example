# ============================================================
# USTURA — Ortam Değişkenleri (Örnek)
# Bu dosyayı .env olarak kopyalayıp değerleri doldurun
# ============================================================

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ustura
DB_USER=postgres
DB_PASSWORD=
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT_MS=5000
DB_IDLE_TIMEOUT_MS=30000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Firebase Google Auth (optional customer sign-in)
FIREBASE_PROJECT_ID=
FIREBASE_CERTS_URL=https://www.googleapis.com/robot/v1/metadata/x509/securetoken@system.gserviceaccount.com

# Backend
PORT=3000
NODE_ENV=development
API_PREFIX=api

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:19006
CORS_CREDENTIALS=true
