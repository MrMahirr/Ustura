# ============================================================
# USTURA — Ortam Değişkenleri (Örnek)
# Bu dosyayı .env olarak kopyalayıp değerleri doldurun
# ============================================================

# PostgreSQL
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_POOL_MIN=
DB_POOL_MAX=
DB_CONNECTION_TIMEOUT_MS=
DB_IDLE_TIMEOUT_MS=

# Redis
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=

# JWT
JWT_SECRET=
JWT_ACCESS_EXPIRATION=
JWT_REFRESH_EXPIRATION=

# Firebase Google Auth (optional customer sign-in)
FIREBASE_PROJECT_ID=
FIREBASE_CERTS_URL=
GOOGLE_WEB_CLIENT_ID=
# Backend
PORT=
NODE_ENV=
API_PREFIX=

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:19006
CORS_CREDENTIALS=true

# EmailJS (salon onaylama e-posta gonderimi)
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_APPROVAL=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=

# Frontend
FRONTEND_BASE_URL=http://localhost:8081
